#!/usr/bin/env bash
# ddc-mode-switcher — Switch dual-mode monitor display modes for gaming.
# Usage: ddc-mode-switcher              → toggle mode
#        ddc-mode-switcher <cmd...>     → switch, run command, restore on exit
#
# Configure via ~/.config/ddc-mode-switcher/config (or DISPLAY_MODE_SWITCHER_CONFIG).
# Requires: ddcutil, i2c_dev loaded. Optional: gdctl (mutter 48+) for verified switching.

set -e

VERSION="2.0.1"
STATE_FILE="/tmp/ddc-mode-switcher-state"

usage() {
    cat <<EOF
ddc-mode-switcher v${VERSION} — Switch dual-mode monitor modes for gaming

Usage:
  ddc-mode-switcher              Toggle mode
  ddc-mode-switcher <cmd...>     Run command in alternate mode, restore on exit

Examples:
  ddc-mode-switcher
  ddc-mode-switcher mangohud %command%    # Steam launch options

Configuration (~/.config/ddc-mode-switcher/config):
  BUS=5                              # I2C bus (find with: ddcutil detect)
  CONN=DP-2                          # Monitor connector (find with: gdctl show)
  NATIVE_RES=5120x2880               # Desktop resolution (the mode to restore to)
  TOGGLE_STEPS=("0x03 1" "0x03 20")  # DDC VCP toggle sequence
  SECONDARY_CONN=DP-3                # Secondary monitor connector (optional)
  DEFAULT_SCALE=1.66                  # Fallback primary scale (optional, default: 1.0)
  DEFAULT_SECONDARY_SCALE=1.0        # Fallback secondary scale (optional, default: 1.0)
  SWITCH_TIMEOUT=10                  # Max seconds for mode confirmation (optional, default: 10)
  FALLBACK_WAIT=2                    # Blind wait when gdctl unavailable (optional, default: 2)

Environment:
  DISPLAY_MODE_SWITCHER_CONFIG       Config file path (overrides default location)
  DISPLAY_MODE_SWITCH_TIMEOUT        Override SWITCH_TIMEOUT from config
EOF
}

# --- Configuration ---

load_config() {
    local user_config="${XDG_CONFIG_HOME:-$HOME/.config}/ddc-mode-switcher/config"
    local config="${DISPLAY_MODE_SWITCHER_CONFIG:-$user_config}"
    local example="/etc/xdg/ddc-mode-switcher/config.example"

    if [[ ! -f "$config" ]]; then
        if [[ -f "$example" ]]; then
            mkdir -p "$(dirname "$user_config")"
            cp "$example" "$user_config"
            config="$user_config"
            echo "ddc-mode-switcher: config created at $user_config" >&2
            echo "Edit it and uncomment/set the required values: BUS, CONN, NATIVE_RES, TOGGLE_STEPS" >&2
            echo "See 'ddc-mode-switcher --help' for details." >&2
            exit 1
        else
            echo "ddc-mode-switcher: no config found and no example at $example" >&2
            echo "See 'ddc-mode-switcher --help' for setup instructions." >&2
            exit 1
        fi
    fi

    source "$config"

    # Validate required settings
    local missing=()
    [[ -z "${BUS:-}" ]] && missing+=(BUS)
    [[ -z "${CONN:-}" ]] && missing+=(CONN)
    [[ -z "${NATIVE_RES:-}" ]] && missing+=(NATIVE_RES)
    [[ ${#TOGGLE_STEPS[@]} -eq 0 ]] 2>/dev/null && missing+=(TOGGLE_STEPS)

    if [[ ${#missing[@]} -gt 0 ]]; then
        echo "ddc-mode-switcher: missing required config in $config: ${missing[*]}" >&2
        echo "See 'ddc-mode-switcher --help' for details." >&2
        exit 1
    fi

    # Defaults
    DEFAULT_SCALE="${DEFAULT_SCALE:-1.0}"
    DEFAULT_SECONDARY_SCALE="${DEFAULT_SECONDARY_SCALE:-1.0}"
    SWITCH_TIMEOUT="${DISPLAY_MODE_SWITCH_TIMEOUT:-${SWITCH_TIMEOUT:-10}}"
    FALLBACK_WAIT="${FALLBACK_WAIT:-2}"
}

# --- Display state (gdctl) ---

get_current_res() {
    gdctl show 2>/dev/null | awk -v target="$CONN" '
        /Monitor / { mconn=$2; gsub(/[()]/,"",mconn) }
        mconn==target && /Current mode/ {
            getline; gsub(/.*──/,""); gsub(/^[[:space:]]+/,"")
            sub(/@.*/, ""); print; exit
        }
    '
}

save_state() {
    gdctl show 2>/dev/null | awk -v pri="$CONN" -v sec="${SECONDARY_CONN:-}" \
        -v ds="$DEFAULT_SCALE" -v dss="$DEFAULT_SECONDARY_SCALE" '
        /Monitor / { mconn=$2; gsub(/[()]/,"",mconn) }
        mconn==pri && /Current mode/ { getline; gsub(/.*──/,""); gsub(/^[[:space:]]+/,""); mode_pri=$0 }
        sec && mconn==sec && /Current mode/ { getline; gsub(/.*──/,""); gsub(/^[[:space:]]+/,""); mode_sec=$0 }
        /Logical monitor/ { lm_scale="" }
        /Scale:/ { gsub(/.*Scale: /,""); lm_scale=$0 }
        /Monitors: \(/ {
            getline
            if (lm_scale && $0 ~ pri) scale_pri=lm_scale
            if (sec && lm_scale && $0 ~ sec) scale_sec=lm_scale
        }
        END {
            print "SAVED_MODE=" mode_pri
            print "SAVED_SCALE=" (scale_pri ? scale_pri : ds)
            print "SAVED_SEC_MODE=" mode_sec
            print "SAVED_SEC_SCALE=" (scale_sec ? scale_sec : dss)
        }
    ' > "$STATE_FILE"
}

do_restore() {
    source "$STATE_FILE" 2>/dev/null || return 1

    if [[ -n "$SAVED_SEC_MODE" && -n "${SECONDARY_CONN:-}" ]]; then
        gdctl set -L -M "$CONN" -m "$SAVED_MODE" -s "$SAVED_SCALE" -p \
               -L -M "$SECONDARY_CONN" --right-of "$CONN" -s "$SAVED_SEC_SCALE" 2>/dev/null
    else
        gdctl set -L -M "$CONN" -m "$SAVED_MODE" -s "$SAVED_SCALE" -p 2>/dev/null
    fi
}

# --- DDC toggle ---

do_toggle() {
    local step
    for step in "${TOGGLE_STEPS[@]}"; do
        # shellcheck disable=SC2086
        ddcutil setvcp $step --bus "$BUS" --noverify 2>/dev/null || true
    done
}

# --- Mode verification ---

# Wait until the monitor resolution changes away from $1, or timeout.
wait_for_mode_change() {
    local from_res="$1"

    if ! (( HAVE_GDCTL )); then
        sleep "$FALLBACK_WAIT"
        return 0
    fi

    local i current_res
    for (( i=0; i<SWITCH_TIMEOUT; i++ )); do
        sleep 1
        current_res=$(get_current_res)
        if [[ -n "$current_res" && "$current_res" != "$from_res" ]]; then
            return 0
        fi
        sleep 1
    done

    return 1
}

# Wait until the monitor resolution matches $1, or timeout.
wait_for_mode_match() {
    local expected_res="$1"

    if ! (( HAVE_GDCTL )); then
        sleep "$FALLBACK_WAIT"
        return 0
    fi

    local i current_res
    for (( i=0; i<SWITCH_TIMEOUT; i++ )); do
        sleep 1
        current_res=$(get_current_res)
        if [[ "$current_res" == "$expected_res" ]]; then
            return 0
        fi
    done

    return 1
}

# --- Main ---

case "${1:-}" in
    -h|--help) usage; exit 0 ;;
    -v|--version) echo "ddc-mode-switcher ${VERSION}"; exit 0 ;;
    -t|--toggle) shift ;;
esac

load_config

# Toggle mode (no arguments)
if [[ $# -eq 0 ]]; then
    do_toggle
    exit 0
fi

# Wrapper mode
HAVE_GDCTL=0
if command -v gdctl &>/dev/null; then
    save_state
    source "$STATE_FILE" 2>/dev/null || true
    if [[ -n "${SAVED_MODE:-}" ]]; then
        HAVE_GDCTL=1
        current_res="${SAVED_MODE%%@*}"
        if [[ "$current_res" != "$NATIVE_RES" ]]; then
            echo "ddc-mode-switcher: already in alternate mode ($current_res), running command directly" >&2
            exec "$@"
        fi
    fi
fi

do_toggle

if ! wait_for_mode_change "$NATIVE_RES"; then
    echo "ddc-mode-switcher: WARNING: mode switch not confirmed after ${SWITCH_TIMEOUT}s, proceeding anyway" >&2
fi

"$@"
GAME_EXIT=$?

do_toggle

if (( HAVE_GDCTL )); then
    if ! wait_for_mode_match "$NATIVE_RES"; then
        echo "ddc-mode-switcher: WARNING: switch back to ${NATIVE_RES} not confirmed after ${SWITCH_TIMEOUT}s, attempting restore anyway" >&2
    fi
    do_restore
fi

exit "$GAME_EXIT"
